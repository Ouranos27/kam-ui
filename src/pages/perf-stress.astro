---
import { ComponentPlayground } from '../components/react/ComponentPlayground';

const slugs = [
	'chromatic-field',
	'shimmer-ring',
	'crown-glow',
	'solar-flare',
	'black-hole',
	'mesh-gradient',
	'atmospheric-sky',
] as const;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Performance Stress Test</title>
	</head>
	<body style="margin:0;background:#050508;color:#e4e4e7;font-family:ui-monospace, SFMono-Regular, Menlo, monospace;">
		<main>
			<header style="position:sticky;top:0;z-index:20;background:rgba(5,5,8,0.85);backdrop-filter:blur(8px);padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.08);">
				<strong>Perf Stress Route</strong>
				<div style="font-size:12px;opacity:0.8;margin-top:4px;">Scroll top-to-bottom repeatedly while recording Chrome Performance timeline.</div>
			</header>
			{
				slugs.map((slug) => (
					<section style="height:82vh;min-height:560px;border-bottom:1px solid rgba(255,255,255,0.08);position:relative;">
						<div style="position:absolute;inset:0;">
							<ComponentPlayground slug={slug} quality="high" client:load />
						</div>
						<div style="position:absolute;left:16px;bottom:16px;padding:6px 8px;border:1px solid rgba(255,255,255,0.18);background:rgba(0,0,0,0.35);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;">
							{slug}
						</div>
					</section>
				))
			}
		</main>
	</body>
</html>
