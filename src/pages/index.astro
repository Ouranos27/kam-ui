---
import '../styles/global.css';
import { componentNav, firstComponentHref } from '../data/nav';
import { MilkyWay } from '../components/react/MilkyWay';

const description = 'kam-ui — animated WebGL and CSS background components for React. Install via shadcn CLI.';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			try {
				const k = 'kam-ui-theme';
				const v = localStorage.getItem(k);
				const r = document.documentElement;
				if (v === 'dark') r.classList.add('dark');
				else if (v === 'system')
					r.classList.toggle('dark', window.matchMedia('(prefers-color-scheme: dark)').matches);
				else r.classList.add('dark');
			} catch {}
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content="kam-ui · Motion registry" />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ui.philippekam.dev" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="kam-ui · Motion registry" />
		<meta name="twitter:description" content={description} />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>kam-ui · Motion registry</title>
	</head>

	<body class="bg-background text-foreground min-h-screen font-sans antialiased overscroll-none">

		<!-- Skip to main -->
		<a class="skip-to-main" href="#main-content">Skip to main content</a>

		<!-- Nav -->
		<nav id="kam-nav" class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-black/50 backdrop-blur-md transition-colors duration-300">
			<div class="mx-auto flex max-w-[1280px] items-center justify-between px-6 py-4">
				<a href="/" class="font-sans text-xl text-white tracking-tight">kam—ui</a>
				<div class="flex items-center gap-6">
					<a href={firstComponentHref} class="text-sm text-white/50 hover:text-white transition-colors" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">Components</a>
					<a href="/design-system" class="text-sm text-white/50 hover:text-white transition-colors" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">Docs</a>
					<a href="https://github.com/Ouranos27/kam-ui" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="GitHub">
						<svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/></svg>
					</a>
					<select id="kam-theme-landing" class="bg-transparent text-sm text-white/50 cursor-pointer border-none outline-none" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">
						<option value="dark">Dark</option>
						<option value="light">Light</option>
						<option value="system">System</option>
					</select>
				</div>
			</div>
		</nav>

		<!-- Hero -->
		<main id="main-content">
			<section class="relative h-dvh w-full overflow-hidden">
				<MilkyWay client:visible brightness={1.2} speed={0.38} className="absolute inset-0" />
				<div class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center">
					<h1 class="animate-fade-up font-sans text-5xl md:text-7xl text-white tracking-tight" style="font-style: italic;">Animated backgrounds<br/>for React</h1>
					<p class="animate-fade-up animate-fade-up-d1 mt-6 max-w-md text-lg text-white/50" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">
						WebGL and CSS components. Install via shadcn CLI.
					</p>
					<div class="animate-fade-up animate-fade-up-d2 mt-10 flex flex-col sm:flex-row items-center gap-4">
						<div class="group/install flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 hover:border-white/20 px-4 py-2.5 transition-all duration-200 ease-out hover:shadow-[0_0_20px_rgba(255,255,255,0.05)]">
							<code class="font-mono text-sm text-white/80">npx shadcn@latest add https://ui.philippekam.dev/r/milky-way.json</code>
							<button id="copy-install-btn" data-install-cmd="npx shadcn@latest add https://ui.philippekam.dev/r/milky-way.json" class="text-white/40 hover:text-white transition-colors cursor-pointer" aria-label="Copy install command">
								<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
							</button>
						</div>
						<a href={firstComponentHref} class="text-sm text-white/50 hover:text-white transition-colors" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">Browse components &rarr;</a>
					</div>
				</div>
			</section>

			<!-- Component grid -->
			<section class="px-6 py-24">
				<div class="mx-auto max-w-[1280px]">
					<p class="mb-12 text-sm text-muted-foreground" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">{componentNav.length} components &middot; shadcn registry &middot; MIT</p>
					<div class="grid gap-px sm:grid-cols-2 lg:grid-cols-3 bg-[#111]">
						{componentNav.map((c) => (
							<a href={c.href} class="group flex flex-col gap-2 p-6 bg-background transition-all duration-200 ease-out hover:bg-card cursor-pointer border-l-2 border-l-transparent hover:border-l-white/60">
								<span class="font-sans text-xl tracking-tight text-muted-foreground group-hover:text-white transition-colors duration-200">{c.title}</span>
								<span class="hidden sm:block text-sm text-muted-foreground line-clamp-2 group-hover:text-foreground/70 transition-colors duration-200" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">{c.description}</span>
								<span class="mt-auto pt-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">{c.specimenEngine || 'CSS'}</span>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- Install block -->
			<section class="px-6 pb-12">
				<div class="mx-auto max-w-[1280px] border border-border p-6">
					<code class="block font-mono text-sm text-muted-foreground">npx shadcn@latest add https://ui.philippekam.dev/r/&lt;component&gt;.json</code>
					<p class="mt-2 text-sm text-muted-foreground" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">Or copy source from any component page.</p>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="px-6 py-8">
			<div class="mx-auto max-w-[1280px]">
				<div class="mb-8 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
			</div>
			<div class="mx-auto flex max-w-[1280px] flex-wrap items-center gap-6 text-sm text-muted-foreground" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;">
				<a href="https://github.com/Ouranos27/kam-ui" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">GitHub</a>
				<a href={firstComponentHref} class="hover:text-foreground transition-colors">Components</a>
				<a href="/r/registry.json" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">Registry JSON</a>
				<span>MIT License</span>
			</div>
		</footer>

		<!-- Theme toggle + copy button -->
		<script is:inline>
			(() => {
				const KEY = 'kam-ui-theme';
				const root = document.documentElement;
				function readStored() {
					const v = localStorage.getItem(KEY);
					if (v === 'light' || v === 'dark' || v === 'system') return v;
					return 'dark';
				}
				function apply(mode) {
					if (mode === 'light') root.classList.remove('dark');
					else if (mode === 'dark') root.classList.add('dark');
					else root.classList.toggle('dark', matchMedia('(prefers-color-scheme: dark)').matches);
				}
				const sel = document.getElementById('kam-theme-landing');
				if (sel instanceof HTMLSelectElement) {
					sel.value = readStored();
					sel.addEventListener('change', () => {
						localStorage.setItem(KEY, sel.value);
						apply(sel.value);
					});
				}
				matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
					if (readStored() === 'system') apply('system');
				});
				const copyBtn = document.getElementById('copy-install-btn');
				if (copyBtn) {
					copyBtn.addEventListener('click', () => {
						const cmd = copyBtn.getAttribute('data-install-cmd');
						if (!cmd) return;
						const svgMarkup = copyBtn.querySelector('svg').outerHTML;
						navigator.clipboard.writeText(cmd).then(() => {
							copyBtn.textContent = 'Copied';
							setTimeout(() => {
								copyBtn.textContent = '';
								const temp = document.createElement('template');
								temp.innerHTML = svgMarkup;
								copyBtn.appendChild(temp.content.firstChild);
							}, 1800);
						});
					});
				}
			})();
		</script>
		<script is:inline>
			(() => {
				const nav = document.getElementById('kam-nav');
				if (!nav) return;
				let scrolled = false;
				function onScroll() {
					const now = window.scrollY > 50;
					if (now !== scrolled) {
						scrolled = now;
						nav.style.backgroundColor = scrolled ? 'rgba(0,0,0,0.8)' : '';
					}
				}
				window.addEventListener('scroll', onScroll, { passive: true });
			})();
		</script>
	</body>
</html>
