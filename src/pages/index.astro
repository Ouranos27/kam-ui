		<!-- Theme toggle + copy button scripts -->
		<script is:inline>
			(() => {
				const KEY = 'kam-ui-theme';
				const root = document.documentElement;

				function readStored() {
					const v = localStorage.getItem(KEY);
					if (v === 'light' || v === 'dark' || v === 'system') return v;
					return 'light';
				}

				function apply(mode) {
					if (mode === 'light') root.classList.remove('dark');
					else if (mode === 'dark') root.classList.add('dark');
					else root.classList.toggle('dark', matchMedia('(prefers-color-scheme: dark)').matches);
				}

				const sel = document.getElementById('kam-theme-landing');
				if (sel instanceof HTMLSelectElement) {
					sel.value = readStored();
					sel.addEventListener('change', () => {
						localStorage.setItem(KEY, sel.value);
						apply(sel.value);
					});
				}

				matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
					if (readStored() === 'system') apply('system');
				});

				// Copy install button
				const copyBtn = document.getElementById('copy-install-btn');
				if (copyBtn) {
					copyBtn.addEventListener('click', () => {
						const cmd = copyBtn.getAttribute('data-install-cmd');
						if (!cmd) return;
						navigator.clipboard.writeText(cmd).then(() => {
							const orig = copyBtn.textContent;
							copyBtn.textContent = 'COPIED';
							setTimeout(() => { copyBtn.textContent = orig; }, 1800);
						});
					});
				}

				// Mobile nav close on link click
				const det = document.getElementById('landing-mobile-nav');
				if (det) {
					det.addEventListener('click', (e) => {
						const a = e.target?.closest('a');
						if (a && det.contains(a)) det.open = false;
					});
				}

				// Mouse spotlight (desktop pointer devices only)
				const spotlight = document.getElementById('landing-spotlight');
				if (spotlight && window.matchMedia('(pointer: fine)').matches) {
					const isDark = () => document.documentElement.classList.contains('dark');
					const setColor = () => {
						spotlight.style.setProperty(
							'--sl-color',
							isDark()
								? 'rgba(255,255,255,0.014)'
								: 'rgba(0,0,0,0.011)',
						);
					};
					setColor();
					// Re-sync color when theme changes
					new MutationObserver(setColor).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

					let active = false;
					window.addEventListener('mousemove', (e) => {
						spotlight.style.setProperty('--sl-x', e.clientX + 'px');
						spotlight.style.setProperty('--sl-y', e.clientY + 'px');
						if (!active) {
							active = true;
							spotlight.style.opacity = '1';
						}
					}, { passive: true });
					window.addEventListener('mouseleave', () => {
						active = false;
						spotlight.style.opacity = '0';
					});
				}
			})();
		</script>
