---
import '../styles/global.css';
import { componentNav, componentNavGrouped, firstComponentHref, firstRegistrySlug } from '../data/nav';
import { MilkyWay } from '../components/react/MilkyWay';

const description =
	'kam-ui — a shadcn-compatible registry of motion-rich React specimens. Deploy with the CLI or extract source.';

const features = [
	{
		index: '01',
		tag: 'FRAME',
		title: 'Rigid 3-Column Architecture',
		blurb:
			'Sidebar, article measure, and technical TOC rail. Clear panels and tonal boundaries without turning the whole site into a themed “console.”',
	},
	{
		index: '02',
		tag: 'COMPONENTS',
		title: 'Previews + Source',
		blurb:
			'Each component page pairs a live preview with install steps and extracted source. Motion-rich where it matters, accessible by default.',
	},
	{
		index: '03',
		tag: 'DEPLOYMENT',
		title: 'shadcn-compatible Registry',
		blurb:
			'Install via generated registry.json entries under /r/. One command into any React + Tailwind + shadcn stack.',
	},
] as const;

const principles = [
	{ tag: 'Clear hierarchy', blurb: 'Docs chrome stays in semantic tokens and spacing — readable navigation, not a costume layer on top of the registry.' },
	{ tag: 'Quiet canvas', blurb: 'Generous whitespace and subtle brand wash so component previews stay the focus.' },
	{ tag: 'Portable components', blurb: 'Registry pieces are framed so they still look at home in a normal shadcn + Tailwind app.' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			try {
				const k = 'kam-ui-theme';
				const v = localStorage.getItem(k);
				const r = document.documentElement;
				if (v === 'dark') r.classList.add('dark');
				else if (v === 'system')
					r.classList.toggle('dark', window.matchMedia('(prefers-color-scheme: dark)').matches);
				else r.classList.add('dark');
			} catch {}
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content="kam-ui · Motion registry" />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ui.philippekam.dev" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="kam-ui · Motion registry" />
		<meta name="twitter:description" content={description} />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>kam-ui · Motion registry</title>
	</head>

	<body class="bg-background text-foreground min-h-screen font-sans antialiased overscroll-none">

		<!-- Skip to main -->
		<a
			class="fixed left-4 top-4 z-200 -translate-y-20 bg-card border border-border px-4 py-2.5 font-mono text-xs font-semibold uppercase tracking-wide focus:translate-y-0 transition-transform duration-200"
			href="#main-content"
		>Skip to main content</a>

		<!-- Mouse spotlight — tight radial that follows the cursor -->
		<div
			id="landing-spotlight"
			class="pointer-events-none fixed inset-0 z-0 opacity-0 transition-opacity duration-700"
			aria-hidden="true"
			style="background: radial-gradient(160px circle at var(--sl-x, 50%) var(--sl-y, 50%), var(--sl-color, transparent), transparent 80%);"
		></div>

		<!-- Registration marks — fixed viewport corners -->
		<div class="pointer-events-none fixed inset-0 z-150" aria-hidden="true">
			<span class="absolute left-4 top-4 text-foreground/15 font-mono text-xs font-bold leading-none select-none">+</span>
			<span class="absolute right-4 top-4 text-foreground/15 font-mono text-xs font-bold leading-none select-none">+</span>
			<span class="absolute left-4 bottom-4 text-foreground/15 font-mono text-xs font-bold leading-none select-none">+</span>
			<span class="absolute right-4 bottom-4 text-foreground/15 font-mono text-xs font-bold leading-none select-none">+</span>
		</div>

		<!-- MAIN NAV -->
		<nav class="border-b border-border sticky top-0 z-100 bg-background" aria-label="Primary">
			<div class="mx-auto flex max-w-[1480px] items-center justify-between gap-4 px-5 py-4 md:px-8 lg:px-12">
				<!-- Logo -->
				<a href="/" class="group shrink-0 cursor-pointer no-underline">
					<span class="font-display text-xl font-black tracking-[-0.04em] text-foreground transition-colors duration-200 group-hover:text-brand">
						KAM<span class="text-brand">—UI</span>
					</span>
					<span
						class="mt-0.5 block text-[9px] font-semibold tracking-[0.2em] uppercase text-muted-foreground"
						style="font-family: var(--font-label, var(--font-mono))"
					>
						React · Tailwind · shadcn registry
					</span>
				</a>

				<!-- Desktop nav links -->
				<ul class="hidden items-center gap-6 list-none p-0 m-0 md:flex">
					{[
						{ label: 'Overview', href: '/', active: true },
						{ label: 'Lab Reference', href: '/design-system', active: false },
						{ label: 'Components', href: firstComponentHref, active: false },
					].map(link => (
						<li>
							<a
								href={link.href}
								class:list={[
									'font-semibold tracking-[0.14em] uppercase transition-colors duration-200 cursor-pointer no-underline text-[10px]',
									link.active
										? 'text-foreground'
										: 'text-muted-foreground hover:text-foreground',
								]}
								style="font-family: var(--font-label, var(--font-mono))"
							>
								{link.label}
							</a>
						</li>
					))}
				</ul>

				<!-- Right: GitHub + Registry + Theme toggle -->
				<div class="flex items-center gap-3 shrink-0">
					<a
						href="https://github.com/Ouranos27/kam-ui"
						target="_blank"
						rel="noopener noreferrer"
						class="hidden md:inline-flex items-center gap-1.5 font-semibold tracking-[0.14em] uppercase text-[9px] text-muted-foreground hover:text-foreground transition-colors duration-200 cursor-pointer no-underline"
						style="font-family: var(--font-label, var(--font-mono))"
						aria-label="GitHub repository"
					>
						<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
						</svg>
					</a>
					<a
						href="/r/registry.json"
						target="_blank"
						rel="noopener noreferrer"
						class="hidden md:inline-flex items-center gap-1.5 font-semibold tracking-[0.14em] uppercase text-[9px] text-muted-foreground hover:text-foreground transition-colors duration-200 cursor-pointer no-underline"
						style="font-family: var(--font-label, var(--font-mono))"
					>
						Registry JSON
						<svg class="size-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M7 7h10v10" />
						</svg>
					</a>
					<label class="sr-only" for="kam-theme-landing">Appearance</label>
					<select
						id="kam-theme-landing"
						class="border border-border bg-background text-foreground h-8 cursor-pointer px-2 font-semibold tracking-[0.12em] uppercase text-[9px] shadow-none transition-colors focus:outline-none focus:ring-1 focus:ring-ring"
						style="font-family: var(--font-label, var(--font-mono))"
					>
						<option value="light">Light</option>
						<option value="dark">Dark</option>
						<option value="system">System</option>
					</select>

					<!-- Mobile menu toggle -->
					<details id="landing-mobile-nav" class="md:hidden relative">
						<summary
							class="border border-border text-muted-foreground hover:text-foreground flex size-8 cursor-pointer list-none items-center justify-center transition-colors [&::-webkit-details-marker]:hidden"
							aria-label="Open menu"
						>
							<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
							</svg>
						</summary>
						<nav class="absolute right-0 top-full mt-2 w-56 border border-border bg-background p-4 shadow-[4px_4px_0_0_color-mix(in_oklch,var(--foreground)_10%,transparent)]" aria-label="Mobile">
							<ul class="flex flex-col gap-2 list-none p-0 m-0">
								{[
									{ label: 'Overview', href: '/' },
									{ label: 'Lab Reference', href: '/design-system' },
									{ label: 'Components', href: firstComponentHref },
									{ label: 'Registry JSON', href: '/r/registry.json' },
									{ label: 'GitHub', href: 'https://github.com/Ouranos27/kam-ui' },
								].map(link => (
									<li>
										<a
											href={link.href}
											class="block py-2 text-sm font-semibold tracking-[0.12em] uppercase text-foreground hover:text-brand transition-colors duration-200 cursor-pointer no-underline"
											style="font-family: var(--font-label, var(--font-mono))"
										>
											{link.label}
										</a>
									</li>
								))}
							</ul>
						</nav>
					</details>
				</div>
			</div>
		</nav>

		<main id="main-content" tabindex="-1">

			<!-- ═══════════════════════════════════════════════════════ -->
			<!-- SECTION 01: THE EDITORIAL COVER — Hero                  -->
			<!-- ═══════════════════════════════════════════════════════ -->
		<section
			class="relative overflow-hidden border-b border-border"
			aria-labelledby="hero-headline"
			style="background-color: var(--background);"
		>
			<!-- Local grid — scrolls with page, prevents fixed-bg parallax slip -->
			<div
				class="absolute inset-0 pointer-events-none"
				aria-hidden="true"
				style="
					background-image:
						linear-gradient(var(--kam-chamber-grid-line) 1px, transparent 1px),
						linear-gradient(90deg, var(--kam-chamber-grid-line) 1px, transparent 1px);
					background-size: 32px 32px;
				"
			></div>
			<!-- Brand radial accent -->
			<div
				class="absolute inset-0 pointer-events-none"
				aria-hidden="true"
				style="background: radial-gradient(ellipse 110% 70% at 45% -5%, color-mix(in oklch, var(--brand) 9%, transparent), transparent 60%);"
			></div>

				<div class="relative kam-landing-container py-20 md:py-28 lg:py-36">
					<div class="grid gap-12 lg:grid-cols-[minmax(0,1.25fr)_minmax(0,0.75fr)] lg:gap-20 xl:gap-28 items-start">

						<!-- LEFT: Main editorial content -->
						<div>
							<!-- Eyebrow label -->
							<p
								class="flex flex-wrap items-center gap-2.5 font-mono text-[10px] font-semibold tracking-[0.22em] uppercase text-muted-foreground"
							>
								<svg
									class="size-3 shrink-0 text-foreground opacity-60"
									viewBox="0 0 12 12"
									fill="none"
									stroke="currentColor"
									stroke-width="1.2"
									aria-hidden="true"
								>
									<path d="M6 1v10M1 6h10" />
								</svg>
								<span>kam-ui: The Editorial Cover</span>
							</p>

							<!-- Main headline -->
							<h1
								id="hero-headline"
								class="kam-shell-heading mt-8 max-w-[16ch]"
								style="letter-spacing: -0.045em; line-height: 1.0;"
							>
								A RIGID REGISTRY<br />FOR ANIMATED<br />SPECIMENS.
							</h1>

							<!-- Body text -->
							<p class="kam-shell-dek mt-6 max-w-lg">
								The cover frames the entire system as a technical publication: hard edges, mono telemetry, and sparse accent signals. Deploy any specimen in minutes.
							</p>

							<!-- Telemetry stats grid -->
							<dl class="mt-10 grid grid-cols-2 gap-x-8 gap-y-4 border-t border-dashed border-border pt-8 font-mono text-[11px] sm:grid-cols-4">
								<div>
									<dt class="text-muted-foreground tracking-wide uppercase">System</dt>
									<dd class="mt-1 font-semibold tracking-tight">kam-ui</dd>
								</div>
								<div>
									<dt class="text-muted-foreground tracking-wide uppercase">Components</dt>
									<dd class="mt-1 font-semibold tracking-tight text-brand">{componentNav.length}</dd>
								</div>
								<div>
									<dt class="text-muted-foreground tracking-wide uppercase">Frame</dt>
									<dd class="mt-1 font-semibold tracking-tight">Editorial</dd>
								</div>
								<div>
									<dt class="text-muted-foreground tracking-wide uppercase">Accent</dt>
									<dd class="mt-1 font-semibold tracking-tight">Electric Blue</dd>
								</div>
							</dl>

							<!-- CTA buttons -->
							<div class="mt-10 flex flex-wrap items-center gap-4">
								<a href={firstComponentHref} class="kam-btn-primary">
									Browse components
									<svg class="size-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7 7 7-7 7" />
									</svg>
								</a>
								<a href="/design-system" class="kam-btn-secondary">
									Lab Reference
								</a>
							</div>
						</div>

						<!-- RIGHT: System manifest card + latest update ticker -->
						<div class="flex flex-col gap-5 lg:pt-2">

							<!-- System manifest card -->
							<div class="kam-data-card p-6">
								<p
									class="mb-5 text-[9px] font-semibold tracking-[0.22em] uppercase text-muted-foreground"
									style="font-family: var(--font-label, var(--font-mono))"
								>
									[ SYSTEM_MANIFEST_V1.1 ]
								</p>
								<dl class="space-y-3 font-mono text-sm">
									<div class="flex items-center justify-between gap-4">
										<dt class="text-muted-foreground uppercase tracking-wide text-[10px]">SPECIMENS</dt>
										<dd class="font-semibold text-brand">{componentNav.length}</dd>
									</div>
									<div class="flex items-center justify-between gap-4">
										<dt class="text-muted-foreground uppercase tracking-wide text-[10px]">ENGINE</dt>
										<dd class="font-semibold">WebGL + CSS</dd>
									</div>
									<div class="flex items-center justify-between gap-4">
										<dt class="text-muted-foreground uppercase tracking-wide text-[10px]">FRAMEWORK</dt>
										<dd class="font-semibold">React 19</dd>
									</div>
									<div class="flex items-center justify-between gap-4">
										<dt class="text-muted-foreground uppercase tracking-wide text-[10px]">STYLING</dt>
										<dd class="font-semibold">Tailwind v4</dd>
									</div>
									<div class="flex items-center justify-between gap-4">
										<dt class="text-muted-foreground uppercase tracking-wide text-[10px]">REGISTRY</dt>
										<dd class="font-semibold text-brand">shadcn</dd>
									</div>
									<div class="flex items-center justify-between gap-4">
										<dt class="text-muted-foreground uppercase tracking-wide text-[10px]">LICENSE</dt>
										<dd class="font-semibold">MIT</dd>
									</div>
								</dl>
							</div>

							<!-- Latest update ticker -->
							<div class="overflow-hidden border border-border">
								<div class="border-b border-border bg-muted/40 px-4 py-2">
									<p
										class="text-[9px] font-semibold tracking-[0.22em] uppercase text-muted-foreground"
										style="font-family: var(--font-label, var(--font-mono))"
									>
										Latest Update
									</p>
								</div>
								<div class="overflow-hidden px-4 py-3">
									<div class="kam-marquee-track font-mono text-[10px] text-muted-foreground" aria-label="Latest updates">
										<span class="pr-16">V0.1-BETA · {componentNav.length} SPECIMENS INDEXED · SHADCN REGISTRY COMPATIBLE · WEBGL + OGL · CSS VARS + rAF · &nbsp;</span>
										<span class="pr-16" aria-hidden="true">V0.1-BETA · {componentNav.length} SPECIMENS INDEXED · SHADCN REGISTRY COMPATIBLE · WEBGL + OGL · CSS VARS + rAF · &nbsp;</span>
									</div>
								</div>
							</div>

							<!-- Install quick-start -->
							<div class="border border-border">
								<div class="border-b border-border bg-muted/40 px-4 py-2">
									<p
										class="text-[9px] font-semibold tracking-[0.22em] uppercase text-muted-foreground"
										style="font-family: var(--font-label, var(--font-mono))"
									>
										Quick Install
									</p>
								</div>
								<div class="flex items-center justify-between gap-2 px-4 py-3">
									<code class="font-mono text-[11px] text-foreground min-w-0 truncate">{`npx shadcn@latest add /r/${firstRegistrySlug}.json`}</code>
									<button
										id="copy-install-btn"
										type="button"
										data-install-cmd={`npx shadcn@latest add https://ui.philippekam.dev/r/${firstRegistrySlug}.json`}
										class="shrink-0 border border-border px-2.5 py-1 font-mono text-[9px] font-semibold uppercase tracking-[0.16em] text-muted-foreground hover:border-foreground hover:text-foreground transition-colors duration-200 cursor-pointer"
										aria-label="Copy install command"
									>
										COPY
									</button>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

		<!-- ═══════════════════════════════════════════════════════ -->
		<!-- SECTION 02: THE TECHNICAL SCHEMATIC — Features          -->
		<!-- ═══════════════════════════════════════════════════════ -->
		<section class="kam-landing-section kam-section-surface" aria-labelledby="schematic-heading">
				<div class="kam-landing-container py-20 md:py-24">
					<div class="mb-12 flex flex-wrap items-baseline gap-4">
						<span class="kam-section-index">02</span>
						<h2
							id="schematic-heading"
							class="font-display text-2xl font-black tracking-[-0.03em] sm:text-3xl"
						>
							THE TECHNICAL SCHEMATIC
						</h2>
						<p class="ml-auto hidden font-mono text-[10px] text-muted-foreground md:block">
							[ SYSTEM_SCAN ] // ARCHITECTURE_INDEXED
						</p>
					</div>

					<!-- 3-column feature grid with "gap-px bg-border" trick for 1px dividers -->
					<div class="grid gap-px bg-border md:grid-cols-3">
						{features.map((f) => (
							<div class="bg-background p-8 md:p-10">
								<p
									class="mb-3 text-brand text-[10px] font-semibold tracking-[0.2em] uppercase"
									style="font-family: var(--font-label, var(--font-mono))"
								>
									{f.tag}
								</p>
								<h3 class="font-display text-lg font-bold tracking-tight">{f.title}</h3>
								<p class="mt-3 text-sm leading-relaxed text-muted-foreground">{f.blurb}</p>
							</div>
						))}
					</div>

					<!-- Operating doctrine cards -->
					<div class="mt-px grid gap-px bg-border md:grid-cols-3">
						{principles.map((p) => (
							<div class="group bg-background p-8 hover:bg-muted/30 transition-colors duration-200 cursor-default">
								<div class="mb-4 flex items-center gap-1.5">
									<span class="size-1 bg-brand" aria-hidden="true"></span>
									<span class="size-1 bg-brand/40" aria-hidden="true"></span>
									<span class="size-1 bg-brand/20" aria-hidden="true"></span>
								</div>
								<h3 class="font-display text-base font-bold tracking-tight">{p.tag}</h3>
								<p class="mt-2.5 text-sm leading-relaxed text-muted-foreground">{p.blurb}</p>
							</div>
						))}
					</div>
				</div>
			</section>

		<!-- ═══════════════════════════════════════════════════════ -->
		<!-- SECTION 03: THE ACTIVE LABORATORY — Component index     -->
		<!-- ═══════════════════════════════════════════════════════ -->
		<section class="kam-landing-section kam-section-tinted" aria-labelledby="lab-heading">
				<div class="kam-landing-container py-20 md:py-24">
					<div class="mb-12 flex flex-wrap items-center justify-between gap-6">
						<div class="flex flex-wrap items-baseline gap-4">
							<span class="kam-section-index">03</span>
							<h2
								id="lab-heading"
								class="font-display text-2xl font-black tracking-[-0.03em] sm:text-3xl"
							>
								THE ACTIVE LABORATORY
							</h2>
						</div>
						<p
							class="hidden font-mono text-[10px] font-semibold text-muted-foreground md:block"
						>
							[ SYNCING_NODE_01 ] // {componentNav.length} SPECIMENS INDEXED
						</p>
					</div>

					<!-- Terminal scan lines animation -->
					<div class="mb-6 border border-dashed border-border p-4">
						<p class="font-mono text-[10px] text-muted-foreground leading-loose">
							<span class="text-brand">{'>'}</span> INITIALIZING ARCHITECTURAL_SHELL...<br />
							<span class="text-brand">{'>'}</span> LOADING GEOMETRY_BUFFERS [<span class="text-brand">OK</span>]<br />
							<span class="text-brand">{'>'}</span> MAPPING VERTEX_INDEX_0492 [<span class="text-brand">OK</span>]<br />
							<span class="text-brand">{'>'}</span> CORE_LATENCY: 1.2MS · RENDER_MODE: WIREFRAME
						</p>
					</div>

					<!-- Component cards — grouped by category -->
					<div class="flex flex-col gap-12 md:gap-14">
						{componentNavGrouped.map((group) => (
