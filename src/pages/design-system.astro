---
import DocsLayout from '../layouts/DocsLayout.astro';

const colorTokens = [
  { name: 'background', var: '--background' },
  { name: 'foreground', var: '--foreground' },
  { name: 'card', var: '--card' },
  { name: 'muted', var: '--muted' },
  { name: 'muted-foreground', var: '--muted-foreground' },
  { name: 'border', var: '--border' },
  { name: 'code', var: '--code' },
  { name: 'code-foreground', var: '--code-foreground' },
] as const;

const radii = [
  { label: 'sm', cls: 'rounded-sm' },
  { label: 'md', cls: 'rounded-md' },
  { label: 'lg', cls: 'rounded-lg' },
  { label: 'xl', cls: 'rounded-xl' },
  { label: '2xl', cls: 'rounded-2xl' },
] as const;
---

<DocsLayout title="Design System" description="Design tokens and typography reference." tocEditPath="src/pages/design-system.astro">
  <div slot="toc" class="space-y-2 text-sm text-muted-foreground">
    <p class="text-foreground/40 mb-3 font-mono text-[9px] font-bold tracking-[0.22em] uppercase">On this page</p>
    <a href="#colors" class="block hover:text-foreground transition-colors">Colors</a>
    <a href="#typography" class="block hover:text-foreground transition-colors">Typography</a>
    <a href="#spacing" class="block hover:text-foreground transition-colors">Spacing</a>
  </div>

  <article>
    <h1 class="font-sans text-4xl tracking-tight mb-12">Design System</h1>

    <!-- Colors -->
    <section id="colors" class="mb-16 scroll-mt-24">
      <h2 class="font-sans text-2xl tracking-tight mb-6">Colors</h2>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
        {colorTokens.map((token) => (
          <div class="flex flex-col items-start gap-2">
            <div
              class="h-16 w-full border border-border"
              style={`background-color: var(${token.var});`}
            />
            <code class="font-mono text-xs text-muted-foreground">{token.var}</code>
          </div>
        ))}
      </div>
    </section>

    <!-- Typography -->
    <section id="typography" class="mb-16 scroll-mt-24">
      <h2 class="font-sans text-2xl tracking-tight mb-6">Typography</h2>
      <div class="space-y-8">
        <div>
          <p class="text-muted-foreground font-mono text-xs mb-2">font-sans &middot; Instrument Serif</p>
          <p class="font-sans text-5xl tracking-tight">Display heading</p>
        </div>
        <div>
          <p class="text-muted-foreground font-mono text-xs mb-2">System font &middot; body</p>
          <p style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 1rem; line-height: 1.6;">
            The quick brown fox jumps over the lazy dog. Body text uses the system font stack for maximum readability and native feel.
          </p>
        </div>
        <div>
          <p class="text-muted-foreground font-mono text-xs mb-2">font-mono &middot; JetBrains Mono</p>
          <pre class="font-mono text-sm bg-code text-code-foreground rounded-md px-4 py-3 overflow-x-auto"><code>const tokens = getDesignTokens();
console.log(tokens.colors);</code></pre>
        </div>
      </div>
    </section>

    <!-- Spacing -->
    <section id="spacing" class="mb-16 scroll-mt-24">
      <h2 class="font-sans text-2xl tracking-tight mb-6">Spacing</h2>
      <p class="text-muted-foreground text-sm mb-6">Border-radius scale</p>
      <div class="flex flex-wrap items-end gap-6">
        {radii.map((r) => (
          <div class="text-center">
            <div class:list={['h-16 w-16 border border-border bg-muted', r.cls]} />
            <p class="mt-2 font-mono text-xs text-muted-foreground">{r.label}</p>
          </div>
        ))}
      </div>
    </section>
  </article>
</DocsLayout>
