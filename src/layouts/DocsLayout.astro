---
import '../styles/global.css';
import Sidebar from '../components/docs/Sidebar.astro';
import TocSidebar from '../components/docs/TocSidebar.astro';
import { ShellBlueprintBackground } from '../components/react/ShellBlueprintBackground';

interface Props {
	title: string;
	description?: string;
	/** Wider article column (e.g. lab reference, specimen dossiers). */
	wide?: boolean;
	/**
	 * `rb-docs` — specimen pages: ~1080px article cap + spacing like react-bits `category-page`.
	 */
	variant?: 'default' | 'rb-docs';
	/** Default "Edit this page" path when the page does not pass `slot="toc"`. */
	tocEditPath?: string;
}

const { title, description, wide = false, variant = 'default', tocEditPath = 'src/pages/index.astro' } = Astro.props;
const outerMax = wide ? 'max-w-[min(86rem,100%)]' : 'max-w-[min(62rem,100%)]';
const articleCap =
	wide && variant === 'rb-docs'
		? 'xl:max-w-[min(67.5rem,100%)]'
		: wide
			? 'xl:max-w-[min(62rem,100%)]'
			: 'xl:max-w-[min(46rem,100%)]';
const contentRowClass =
	variant === 'rb-docs'
		? 'mx-auto flex w-full min-w-0 flex-1 flex-col gap-12 px-4 py-8 md:gap-16 md:px-8 md:py-12 lg:gap-20 lg:pt-14 lg:pb-16'
		: 'mx-auto flex w-full min-w-0 flex-1 flex-col gap-10 px-4 py-8 md:px-8 lg:py-12';
const footerMax = outerMax;
const fullTitle = title === 'kam-ui' ? title : `${title} · kam-ui`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			try {
				const k = 'kam-ui-theme';
				const v = localStorage.getItem(k);
				const r = document.documentElement;
				if (v === 'dark') r.classList.add('dark');
				else if (v === 'system')
					r.classList.toggle('dark', window.matchMedia('(prefers-color-scheme: dark)').matches);
				else r.classList.add('dark');
			} catch {}
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<meta property="og:title" content={fullTitle} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={`https://ui.philippekam.dev${Astro.url.pathname}`} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={fullTitle} />
		{description && <meta name="twitter:description" content={description} />}
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
	</head>
	<body>
		<a class="skip-to-main" href="#kam-main-content">Skip to main content</a>

		<!-- Docs shell: full-height flex layout on desktop -->
		<div class="lg:flex">
			<Sidebar currentPath={Astro.url.pathname} />

			<!-- Main column — sits to the right of the sidebar -->
			<div class="kam-shell-stage--live-blueprint relative flex min-h-dvh min-w-0 flex-1 flex-col bg-background">
				<ShellBlueprintBackground client:visible />

				<!-- Sticky content-header bar (desktop only) -->
				<header
					class="border-border bg-background relative z-10 hidden shrink-0 items-center justify-between gap-4 border-b px-6 py-3 lg:sticky lg:top-0 lg:z-40 lg:flex"
					aria-label="Page context"
				>
					<div
						class="flex items-center gap-0 font-mono text-[9px] uppercase tracking-[0.22em] text-muted-foreground"
					>
						<a href="/" class="hover:text-foreground transition-colors duration-200">KAM-UI</a>
						<span class="mx-2 opacity-25" aria-hidden="true">/</span>
						<span class="text-foreground/80">{title.toUpperCase()}</span>
					</div>
					<span class="font-mono text-[9px] uppercase tracking-[0.16em] text-muted-foreground/60"
						>V0.1-BETA</span
					>
				</header>

				<!-- Page content -->
				<main
					id="kam-main-content"
					tabindex="-1"
					class="relative z-10 flex min-h-0 flex-1 flex-col focus:outline-none"
				>
					<!-- Full-bleed hero slot — no padding/max-width; used by background component pages -->
					<slot name="hero" />

					<div class="text-foreground flex flex-1 pb-8 text-[1.05rem] sm:text-[15px]">
						<div
							class:list={[
								contentRowClass,
								outerMax,
								/* stretch: aside must match article height or sticky TOC has no room to stick */
								'xl:flex-row xl:items-stretch xl:gap-16',
							]}
						>
							<div class:list={['min-w-0 flex-1', articleCap]}>
								<slot />
							</div>
							<aside class="hidden w-46 shrink-0 xl:block xl:min-h-0" aria-label="Page outline">
								<slot name="toc">
									<TocSidebar editPath={tocEditPath} />
								</slot>
							</aside>
						</div>
					</div>
				</main>

				<footer
					class="border-border/60 text-muted-foreground relative z-10 mt-auto shrink-0 border-t px-4 py-6 text-sm md:px-6"
				>
					<div
						class:list={[
							'mx-auto flex w-full flex-col gap-2 sm:flex-row sm:items-center sm:justify-between',
							footerMax,
						]}
					>
						<span>
							Built with{' '}
							<a href="https://astro.build/" class="kam-link">Astro</a>
							{' · '}
							<a href="https://ui.shadcn.com/docs/registry" class="kam-link">shadcn registry</a>
						</span>
						<a
							href="/r/registry.json"
							class="kam-link inline-flex items-center gap-1"
							target="_blank"
							rel="noopener noreferrer"
						>
							registry.json
							<span class="sr-only"> (opens in new tab)</span>
							<svg
								class="text-muted-foreground size-3.5 shrink-0 opacity-80"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								aria-hidden="true"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M7 17 17 7M7 7h10v10"></path>
							</svg>
						</a>
					</div>
				</footer>
			</div>
		</div>

		<script is:inline>
			(() => {
				const KEY = 'kam-ui-theme';
				const root = document.documentElement;
				function readStored() {
					const v = localStorage.getItem(KEY);
					if (v === 'light' || v === 'dark' || v === 'system') return v;
					return 'light';
				}
				function apply(mode) {
					if (mode === 'light') root.classList.remove('dark');
					else if (mode === 'dark') root.classList.add('dark');
					else root.classList.toggle('dark', matchMedia('(prefers-color-scheme: dark)').matches);
				}
				const sel = document.getElementById('kam-theme');
				if (sel instanceof HTMLSelectElement) {
					sel.value = readStored();
					sel.addEventListener('change', () => {
						localStorage.setItem(KEY, sel.value);
						apply(sel.value);
					});
				}
				matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
					if (readStored() === 'system') apply('system');
				});
			})();
		</script>
	</body>
</html>
