---
interface Props {
	packages: string[];
	/** e.g. path alias note for copy-paste */
	note?: string;
}

const { packages, note } = Astro.props;
---

<div class="kam-ds-spec kam-ds-dotfield p-5">
	<p class="text-muted-foreground mb-1 font-mono text-[10px] font-semibold tracking-[0.22em] uppercase">Packages</p>
	<h3 class="font-display text-foreground mb-2 text-lg font-semibold tracking-tight">Dependencies</h3>
	<p class="text-muted-foreground text-sm leading-relaxed">
		Install these in your React + Tailwind project before mounting specimen source.
	</p>
	{
		note && (
			<p
				class="border-foreground/40 text-muted-foreground mt-4 border-l-2 border-dashed pl-4 text-sm leading-relaxed"
			>
				{note}
			</p>
		)
	}
	<ul class="mt-4 flex flex-col gap-2">
		{
			packages.map((pkg) => (
				<li>
					<code class="bg-muted text-foreground rounded-none px-[0.3rem] py-[0.2rem] font-mono text-sm">
						{pkg}
					</code>
				</li>
			))
		}
	</ul>
</div>
