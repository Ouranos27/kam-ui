---
import { Code } from 'astro/components';

interface Props {
	code: string;
	/** Shiki language id (e.g. tsx, css) */
	lang?: string;
	filename?: string;
}

const { code, lang = 'tsx', filename } = Astro.props;
const copyRootId = `copy-root-${crypto.randomUUID()}`;
---

<figure class="group" id={copyRootId}>
	<div class="overflow-hidden rounded-lg border border-white/[0.06] shadow-[0_2px_12px_-4px_rgba(0,0,0,0.5)]">
		<!-- Title bar -->
		<div class="flex h-10 shrink-0 items-center justify-between border-b border-white/[0.06] bg-[#0a0a0a] px-4">
			<!-- Traffic lights -->
			<div class="flex shrink-0 items-center gap-[7px]" aria-hidden>
				<span class="size-[11px] rounded-full bg-[#ff5f57]"></span>
				<span class="size-[11px] rounded-full bg-[#febc2e]"></span>
				<span class="size-[11px] rounded-full bg-[#28c840]"></span>
			</div>

			{filename && (
				<span class="pointer-events-none absolute inset-x-0 overflow-hidden text-ellipsis text-center font-mono text-[11px] tracking-wider text-white/25 select-none px-24 whitespace-nowrap">
					{filename}
				</span>
			)}

			<!-- Copy button -->
			<button
				type="button"
				class="copy-btn relative z-10 flex size-7 cursor-pointer items-center justify-center rounded text-white/25 hover:text-white/60 transition-colors duration-150"
				aria-label="Copy code"
			>
				<svg class="copy-icon size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="9" y="9" width="13" height="13" rx="2" />
					<path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
				</svg>
			</button>
		</div>

		<!-- Code body -->
		<div class="bg-[#0f0f0f] [&_pre]:m-0 [&_pre]:overflow-x-auto [&_pre]:rounded-none [&_pre]:border-0 [&_pre]:bg-transparent! [&_pre]:px-4 [&_pre]:py-4 [&_pre]:text-[13px] [&_pre]:leading-relaxed">
			<Code code={code} lang={lang} theme="github-dark" wrap />
		</div>
	</div>
</figure>

<script define:vars={{ copyRootId }}>
	const root = document.getElementById(copyRootId);
	const btn = root?.querySelector('.copy-btn');
	const icon = btn?.querySelector('.copy-icon');
	btn?.addEventListener('click', async () => {
		const pre = root?.querySelector('pre');
		const text = pre?.innerText ?? '';
		try {
			await navigator.clipboard.writeText(text);
			if (btn && icon) {
				btn.classList.remove('text-white/25');
				btn.classList.add('text-white');
				icon.setAttribute('viewBox', '0 0 24 24');
				icon.setAttribute('stroke-width', '2');
				icon.replaceChildren();
				const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
				path.setAttribute('d', 'M5 13l4 4L19 7');
				icon.appendChild(path);
				btn.setAttribute('aria-label', 'Copied');
			}
			setTimeout(() => {
				if (btn && icon) {
					btn.classList.remove('text-white');
					btn.classList.add('text-white/25');
					icon.setAttribute('stroke-width', '1.5');
					icon.replaceChildren();
					const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
					rect.setAttribute('x', '9'); rect.setAttribute('y', '9');
					rect.setAttribute('width', '13'); rect.setAttribute('height', '13');
					rect.setAttribute('rx', '2');
					const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
					path.setAttribute('d', 'M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1');
					icon.appendChild(rect);
					icon.appendChild(path);
					btn.setAttribute('aria-label', 'Copy code');
				}
			}, 2000);
		} catch {
			/* clipboard unavailable */
		}
	});
</script>
